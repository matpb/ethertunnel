# EtherTunnel relay configuration (example).
# Copy to /etc/ethertunnel/relay.toml and edit.

[server]
# Base domain. Tunnels live at <label>.<domain>; daemons connect to
# connect.<domain>. The wildcard *.<domain> and connect.<domain> must resolve
# to this server's public IP (DNS-only / grey-cloud; traffic does not transit
# Cloudflare).
domain = "ethertunnel.com"
# Public listen address. One socket serves visitors and daemon control.
listen = "0.0.0.0:443"
# Body returned for a plain GET on the apex.
apex_response = "EtherTunnel relay"

[tls]
# "acme" (production wildcard via Let's Encrypt DNS-01), "self_signed" (dev),
# or "manual" (operator-provided files).
mode = "acme"
# Where issued certs and the ACME account are cached.
state_dir = "/var/lib/ethertunnel/tls"

[tls.acme]
# Contact email for the ACME account / expiry notices.
email = "you@example.com"
# Always issue against staging first on a fresh deployment, then flip to false.
staging = true

[tls.acme.cloudflare]
# Zone id for the base domain.
zone_id = "your-cloudflare-zone-id"
# File holding a Cloudflare API token with Zone:DNS:Edit on the zone.
# Keep it 0600 and owned by the relay user; never inline the token here.
api_token_file = "/etc/ethertunnel/cloudflare.token"

# Operator-provided certificate (only when mode = "manual").
# [tls.manual]
# cert_file = "/etc/ethertunnel/fullchain.pem"
# key_file = "/etc/ethertunnel/key.pem"

[registry]
db_path = "/var/lib/ethertunnel/registry.db"

[tcp]
# Inclusive public-port range daemons may reserve for raw-TCP tunnels.
port_range = [20000, 20999]
