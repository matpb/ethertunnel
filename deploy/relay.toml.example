# EtherTunnel relay configuration (example).
# Copy to /etc/ethertunnel/relay.toml and edit.

[server]
# Base domain. Tunnels live at <label>.<domain>; daemons connect to
# connect.<domain>. The wildcard *.<domain> and connect.<domain> must resolve
# to this server's public IP (DNS-only / grey-cloud; traffic does not transit
# Cloudflare).
domain = "ethertunnel.com"
# Public listen address. One socket serves visitors and daemon control.
listen = "0.0.0.0:443"
# Body returned for a plain GET on the apex.
apex_response = "EtherTunnel relay"

[tls]
# "acme" (production wildcard via Let's Encrypt DNS-01), "self_signed" (dev),
# or "manual" (operator-provided files).
mode = "acme"
# Where issued certs and the ACME account are cached.
state_dir = "/var/lib/ethertunnel/tls"

[tls.acme]
# Contact email for the ACME account / expiry notices.
email = "you@example.com"
# Always issue against staging first on a fresh deployment, then flip to false.
staging = true

[tls.acme.cloudflare]
# Zone id for the base domain.
zone_id = "your-cloudflare-zone-id"
# File holding a Cloudflare API token with Zone:DNS:Edit on the zone.
# Keep it 0600 and owned by the relay user; never inline the token here.
api_token_file = "/etc/ethertunnel/cloudflare.token"

# Operator-provided certificate (only when mode = "manual").
# [tls.manual]
# cert_file = "/etc/ethertunnel/fullchain.pem"
# key_file = "/etc/ethertunnel/key.pem"

[registry]
db_path = "/var/lib/ethertunnel/registry.db"

[tcp]
# Inclusive public-port range daemons may reserve for raw-TCP tunnels.
# IMPORTANT: this entire range must be opened INBOUND on the host firewall AND
# the cloud security group, or --tcp tunnels fail silently (HTTPS tunnels need
# only :443). See the "Firewall / raw-TCP" section in deploy/DEPLOY.md for the
# exact `ufw allow 20000:20999/tcp` and cloud-console steps.
port_range = [20000, 20999]

# keygate licensing / entitlement enforcement. OMIT this whole section for a
# self-host relay: with no [keygate] block the relay does not enforce any cap and
# every account is allowed (fail-open) — the correct default for self-host.
#
# Hosted / commercial relays MUST include this section AND set
# require_entitlement = true. With it true, a user with no fresh, signed
# entitlement is denied (fail-closed); leaving it false (the built-in default)
# means a relay that loses contact with keygate keeps serving cancelled accounts.
# [keygate]
# base_url = "https://license.ethertunnel.com"
# # File holding the consumer bearer token keygate issued this relay (0600).
# consumer_token_file = "/etc/ethertunnel/keygate.token"
# # keygate's pinned Ed25519 public key (base64, standard) used to verify the
# # signed entitlement envelopes offline.
# public_key = "BASE64_ED25519_PUBLIC_KEY"
# # The signing key id this relay accepts (rotation guard).
# key_id = "kg-2026-06"
# # Product the entitlements are scoped to.
# product = "ethertunnel"
# # How often to pull the entitlement snapshot from keygate (seconds).
# poll_interval_secs = 60
# # Honor a cached envelope at most this many seconds past its expires_at.
# staleness_ceiling_secs = 259200
# # Hosted/commercial: set TRUE so unentitled users are denied. Self-host leaves
# # this false (and normally omits the whole [keygate] section).
# require_entitlement = true
